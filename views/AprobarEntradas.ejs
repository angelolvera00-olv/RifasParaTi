<% layout('layouts/boilerplate') %>

<div class="container mt-5">

    <h2 class="headerChange mb-4 text-center">Aprobar Entradas Apartadas</h2>

    <% if (Object.keys(agrupados).length > 0) { %>

        <form method="POST" action="/AprobarSeleccion">

            <div class="card shadow">
                <div class="card-body">

                    <table class="table table-striped table-hover align-middle text-center">
                        <thead class="table-dark">
                            <tr>
                                <th>Nombre</th>
                                <th>Números Seleccionados</th>
                                <th>Aprobar</th>
                            </tr>
                        </thead>
                        <tbody>

                            <% Object.keys(agrupados).forEach(function(nombre,index) { %>
                                <tr>
                                    <td><%= nombre %></td>

                                    <td>
                                        <% agrupados[nombre].forEach(function(item) { %>
                                            <span class="badge bg-primary me-1">
                                                <%= item.number %>
                                            </span>

                                            <input 
                                                type="checkbox"
                                                name="seleccionados"
                                                value="<%= item.id %>"
                                                class="d-none checkbox-group-<%= index %> "
                                            >
                                        <% }) %>
                                    </td>

                                    <td>
                                        <input 
                                            type="checkbox"
                                            onclick="toggleCheckboxes('<%= index %>', this)"
                                        >
                                    </td>
                                </tr>
                            <% }) %>

                        </tbody>
                    </table>

                    <div class="text-end">
                        <button class="btn btn-success me-2" type="submit" formaction="/AprobarSeleccion" formmethod="post">
                            Guardar Selección
                        </button>

                        <button class="btn btn-danger" type="submit" formaction="/EliminarSeleccion" formmethod="post">
                            Eliminar Selección
                        </button>
                    </div>

                </div>
            </div>

        </form>

    <% } else { %>

        <div class="alert alert-warning text-center">
            No hay entradas apartadas.
        </div>

    <% } %>

</div>

<script>
function toggleCheckboxes(index, mainCheckbox) {
    const checkboxes = document.querySelectorAll('.checkbox-group-' + index);
    checkboxes.forEach(cb => cb.checked = mainCheckbox.checked);
}
</script>
